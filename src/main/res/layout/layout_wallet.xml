<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/container_wallet"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:visibility="gone">

    <LinearLayout
        android:id="@+id/wallet_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="20dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="My Wallet"
            android:textColor="@color/text_white"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#2238BDF8"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="● Online"
            android:textColor="@color/cyan"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav_wallet"
        app:layout_constraintTop_toBottomOf="@id/wallet_header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="20dp">

            <!-- Wallet Hero Card -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/wallet_hero"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:background="@drawable/wallet_card_bg"
                android:padding="22dp">

                <TextView
                    android:id="@+id/wh_lbl"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💳 UPI WALLET BALANCE"
                    android:textColor="#CCFFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:id="@+id/wh_bal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:text="₹0"
                    android:textColor="@color/white"
                    android:textSize="38sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toBottomOf="@id/wh_lbl"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:text="Linked to SBI ••••4821"
                    android:textColor="#99FFFFFF"
                    android:textSize="11sp"
                    app:layout_constraintTop_toBottomOf="@id/wh_bal"
                    app:layout_constraintStart_toStartOf="parent" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:orientation="horizontal"
                    app:layout_constraintTop_toBottomOf="@id/wh_bal"
                    android:layout_marginVertical="40dp">
                    <TextView
                        android:id="@+id/btn_add_money_confirm"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:background="#22FFFFFF"
                        android:gravity="center"
                        android:padding="9dp"
                        android:text="＋ Add Money"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="4dp"
                        android:background="#22FFFFFF"
                        android:gravity="center"
                        android:padding="9dp"
                        android:text="↑ Transfer"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:background="#22FFFFFF"
                        android:gravity="center"
                        android:padding="9dp"
                        android:text="↓ Withdraw"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Stats -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@color/s2"
                    android:padding="13dp"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="THIS MONTH" android:textColor="@color/text_grey" android:textSize="9sp" android:textStyle="bold" />
                    <TextView android:id="@+id/tv_month_spent" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="₹0" android:textColor="@color/error_red" android:textSize="16sp" android:textStyle="bold" />
                </LinearLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="4dp"
                    android:background="@color/s2"
                    android:padding="13dp"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="RECEIVED" android:textColor="@color/text_grey" android:textSize="9sp" android:textStyle="bold" />
                    <TextView android:id="@+id/tv_month_received" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="₹0" android:textColor="@color/success_green" android:textSize="16sp" android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <include
        android:id="@+id/bottom_nav_wallet"
        layout="@layout/common_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>