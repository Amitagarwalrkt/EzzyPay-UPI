<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/user_result_row"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@color/s3"
    android:padding="11dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <TextView
        android:id="@+id/user_avatar"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:background="@drawable/btn_primary_bg"
        android:gravity="center"
        android:text="PS"
        android:textColor="@color/white"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="11dp"
        android:orientation="vertical">
        <TextView
            android:id="@+id/user_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Priya Singh"
            android:textColor="@color/text_white"
            android:textSize="14sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/user_upi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="priya@oksbi"
            android:textColor="@color/text_grey"
            android:textSize="11sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/user_selection_indicator"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:background="@color/cyan"
        android:gravity="center"
        android:text="✓"
        android:textColor="@color/black"
        android:textSize="10sp"
        android:textStyle="bold"
        android:visibility="gone" />
</LinearLayout>