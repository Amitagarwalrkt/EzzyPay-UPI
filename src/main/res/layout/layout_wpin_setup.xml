<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/container_wpin_setup"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:visibility="gone">

    <LinearLayout
        android:id="@+id/wpin_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/btn_back_wpin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:text="← Back"
            android:textColor="@color/text_grey"
            android:textSize="14sp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/wpin_header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingBottom="30dp">

            <TextView
                android:id="@+id/wpin_setup_icon"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:background="@drawable/wallet_card_offline_bg"
                android:gravity="center"
                android:text="🔐"
                android:textSize="32sp" />

            <TextView
                android:id="@+id/wpin_setup_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Create Wallet PIN"
                android:textColor="@color/text_white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/wpin_setup_sub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:text="Set a 4-digit WPIN to secure\nyour offline wallet payments"
                android:textColor="@color/text_grey"
                android:textSize="13sp" />

            <!-- Step Indicator -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="24dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingHorizontal="40dp">

                <TextView
                    android:id="@+id/si_circle_1"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:background="@drawable/pin_dot_empty"
                    android:backgroundTint="@color/amber"
                    android:gravity="center"
                    android:text="1"
                    android:textColor="@color/black"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <View
                    android:id="@+id/si_line_1"
                    android:layout_width="40dp"
                    android:layout_height="2dp"
                    android:background="@color/s3" />

                <TextView
                    android:id="@+id/si_circle_2"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:background="@drawable/pin_dot_empty"
                    android:gravity="center"
                    android:text="2"
                    android:textColor="@color/text_grey"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <View
                    android:id="@+id/si_line_2"
                    android:layout_width="40dp"
                    android:layout_height="2dp"
                    android:background="@color/s3" />

                <TextView
                    android:id="@+id/si_circle_3"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:background="@drawable/pin_dot_empty"
                    android:gravity="center"
                    android:text="✓"
                    android:textColor="@color/text_grey"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:background="@color/s2"
                android:padding="14dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💡 Your WPIN is stored locally on your device. It never goes online. Choose a PIN you'll remember but others can't guess."
                    android:textColor="@color/text_white"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/wpin_entry_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Enter a new 4-digit WPIN"
                android:textColor="@color/text_grey"
                android:textSize="14sp" />

            <LinearLayout
                android:id="@+id/wpin_dots_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">
                <View android:layout_width="16dp" android:layout_height="16dp" android:layout_margin="6dp" android:background="@drawable/pin_dot_empty" />
                <View android:layout_width="16dp" android:layout_height="16dp" android:layout_margin="6dp" android:background="@drawable/pin_dot_empty" />
                <View android:layout_width="16dp" android:layout_height="16dp" android:layout_margin="6dp" android:background="@drawable/pin_dot_empty" />
                <View android:layout_width="16dp" android:layout_height="16dp" android:layout_margin="6dp" android:background="@drawable/pin_dot_empty" />
            </LinearLayout>

            <GridLayout
                android:id="@+id/numpad_wpin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:columnCount="3"
                android:padding="16dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:padding="16dp" android:text="1" android:textColor="@color/text_white" android:textSize="24sp" android:textStyle="bold" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:padding="16dp" android:text="2" android:textColor="@color/text_white" android:textSize="24sp" android:textStyle="bold" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:padding="16dp" android:text="3" android:textColor="@color/text_white" android:textSize="24sp" android:textStyle="bold" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:padding="16dp" android:text="4" android:textColor="@color/text_white" android:textSize="24sp" android:textStyle="bold" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:padding="16dp" android:text="5" android:textColor="@color/text_white" android:textSize="24sp" android:textStyle="bold" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:padding="16dp" android:text="6" android:textColor="@color/text_white" android:textSize="24sp" android:textStyle="bold" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:padding="16dp" android:text="7" android:textColor="@color/text_white" android:textSize="24sp" android:textStyle="bold" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:padding="16dp" android:text="8" android:textColor="@color/text_white" android:textSize="24sp" android:textStyle="bold" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:padding="16dp" android:text="9" android:textColor="@color/text_white" android:textSize="24sp" android:textStyle="bold" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:padding="16dp" android:text="0" android:textColor="@color/text_white" android:textSize="24sp" android:textStyle="bold" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:padding="16dp" android:text="⌫" android:textColor="@color/text_grey" android:textSize="24sp" android:textStyle="bold" />
            </GridLayout>

            <Button
                android:id="@+id/btn_save_wpin"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_margin="20dp"
                android:background="@drawable/wallet_card_offline_bg"
                android:text="🔐 Save WPIN"
                android:textAllCaps="false"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>