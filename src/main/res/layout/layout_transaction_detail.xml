<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/container_txn_detail"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:visibility="gone">

    <LinearLayout
        android:id="@+id/txn_detail_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/btn_back_txn_detail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:text="← History"
            android:textColor="@color/text_grey"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:text="Transaction"
            android:textColor="@color/text_white"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingBottom="14dp"
            android:text="Full payment details"
            android:textColor="@color/text_grey"
            android:textSize="12sp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txn_detail_header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="30dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/detail_type_icon"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="#11EF4444"
                    android:gravity="center"
                    android:text="↑"
                    android:textColor="@color/error_red"
                    android:textSize="32sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Amount Sent"
                    android:textColor="@color/text_grey"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/detail_amount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="−₹658"
                    android:textColor="@color/error_red"
                    android:textSize="38sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="#2238BDF8"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:text="✓ SUCCESS · ONLINE"
                    android:textColor="@color/cyan"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                android:background="@color/s2"
                android:padding="14dp"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/detail_av"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/btn_primary_bg"
                    android:gravity="center"
                    android:text="PS"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/detail_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Priya Singh"
                        android:textColor="@color/text_white"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/detail_upi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="priya@oksbi"
                        android:textColor="@color/text_grey"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:background="@color/s2"
                android:orientation="vertical"
                android:padding="4dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="12dp" android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Transaction ID" android:textColor="@color/text_grey" android:textSize="13sp" />
                    <TextView android:id="@+id/detail_txn_id" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="UPI2403030001" android:textColor="@color/text_white" android:textSize="13sp" android:textStyle="bold" />
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/bg_dark" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="12dp" android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Date &amp; Time" android:textColor="@color/text_grey" android:textSize="13sp" />
                    <TextView android:id="@+id/detail_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mar 3, 4:47 PM" android:textColor="@color/text_white" android:textSize="13sp" android:textStyle="bold" />
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/bg_dark" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="12dp" android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Bank Used" android:textColor="@color/text_grey" android:textSize="13sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SBI ••••4821" android:textColor="@color/text_white" android:textSize="13sp" android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <Button
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_margin="16dp"
                android:background="@drawable/glass_btn_bg"
                android:text="📤 Share Receipt"
                android:textAllCaps="false"
                android:textColor="@color/text_white"
                android:textStyle="bold" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>