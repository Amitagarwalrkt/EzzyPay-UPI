<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/container_success"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:visibility="gone">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/success_icon"
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:background="@drawable/pin_dot_empty"
            android:backgroundTint="@color/success_green"
            android:gravity="center"
            android:text="✓"
            android:textColor="@color/success_green"
            android:textSize="40sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/success_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Payment Saved!"
            android:textColor="@color/text_white"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/success_to_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="to Priya Singh · priya@oksbi"
            android:textColor="@color/text_grey"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/success_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="₹350.00"
            android:textColor="@color/success_green"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/sync_pending_pill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#22FFB800"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:text="⚡ OFFLINE · PENDING SYNC"
            android:textColor="@color/amber"
            android:textSize="11sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/receipt_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@color/s2"
            android:orientation="vertical"
            android:padding="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="6dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Ref ID" android:textColor="@color/text_grey" android:textSize="12sp" />
                <TextView android:id="@+id/tv_success_ref_id" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="EPY-OFF-24031" android:textColor="@color/text_white" android:textSize="12sp" android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="6dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Mode" android:textColor="@color/text_grey" android:textSize="12sp" />
                <TextView android:id="@+id/tv_success_mode" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⚡ Offline Wallet" android:textColor="@color/amber" android:textSize="12sp" android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="6dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Sync Status" android:textColor="@color/text_grey" android:textSize="12sp" />
                <TextView android:id="@+id/tv_success_sync_status" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pending 🕐" android:textColor="@color/amber" android:textSize="12sp" android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/btn_success_home"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/wallet_card_offline_bg"
            android:text="🏠 Back to Home"
            android:textAllCaps="false"
            android:textColor="@color/black"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_share_receipt"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/glass_btn_bg"
            android:text="📤 Share Receipt"
            android:textAllCaps="false"
            android:textColor="@color/text_white"
            android:textStyle="bold" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>