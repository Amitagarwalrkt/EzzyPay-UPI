<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/container_pin"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:visibility="gone">

    <TextView
        android:id="@+id/btn_back_pin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:text="← Back"
        android:textColor="@color/text_grey"
        android:textSize="14sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/pin_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintTop_toBottomOf="@id/btn_back_pin">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/s2"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="10dp"
            android:layout_marginBottom="18dp">
            <TextView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:background="@drawable/wallet_card_bg"
                android:gravity="center"
                android:text="🏦"
                android:textSize="14sp" />
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Paying via"
                    android:textColor="@color/text_grey"
                    android:textSize="10sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="State Bank of India"
                    android:textColor="@color/text_white"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/enter_pin"
            android:textColor="@color/text_grey"
            android:textSize="13sp" />

        <LinearLayout
            android:id="@+id/pin_dots_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">
            <View android:layout_width="12dp" android:layout_height="12dp" android:layout_margin="6dp" android:background="@drawable/pin_dot_empty" />
            <View android:layout_width="12dp" android:layout_height="12dp" android:layout_margin="6dp" android:background="@drawable/pin_dot_empty" />
            <View android:layout_width="12dp" android:layout_height="12dp" android:layout_margin="6dp" android:background="@drawable/pin_dot_empty" />
            <View android:layout_width="12dp" android:layout_height="12dp" android:layout_margin="6dp" android:background="@drawable/pin_dot_empty" />
            <View android:layout_width="12dp" android:layout_height="12dp" android:layout_margin="6dp" android:background="@drawable/pin_dot_empty" />
            <View android:layout_width="12dp" android:layout_height="12dp" android:layout_margin="6dp" android:background="@drawable/pin_dot_empty" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/pin_security_hint"
            android:textColor="@color/text_grey"
            android:textSize="10sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/txn_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:background="@color/s2"
        android:padding="14dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/pin_header">
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sending to"
                android:textColor="@color/text_grey"
                android:textSize="11sp" />
            <TextView
                android:id="@+id/tv_pin_receiver_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Priya Singh"
                android:textColor="@color/text_white"
                android:textSize="14sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tv_pin_receiver_upi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="priya@oksbi"
                android:textColor="@color/text_grey"
                android:textSize="11sp" />
        </LinearLayout>
        <TextView
            android:id="@+id/pin_screen_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₹500"
            android:textColor="@color/cyan"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <GridLayout
        android:id="@+id/numpad_pin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:padding="12dp"
        app:layout_constraintBottom_toTopOf="@id/btn_confirm_pin">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:padding="14dp" android:text="1" android:textColor="@color/text_white" android:textSize="24sp" android:textStyle="bold" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:padding="14dp" android:text="2" android:textColor="@color/text_white" android:textSize="24sp" android:textStyle="bold" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:padding="14dp" android:text="3" android:textColor="@color/text_white" android:textSize="24sp" android:textStyle="bold" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:padding="14dp" android:text="4" android:textColor="@color/text_white" android:textSize="24sp" android:textStyle="bold" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:padding="14dp" android:text="5" android:textColor="@color/text_white" android:textSize="24sp" android:textStyle="bold" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:padding="14dp" android:text="6" android:textColor="@color/text_white" android:textSize="24sp" android:textStyle="bold" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:padding="14dp" android:text="7" android:textColor="@color/text_white" android:textSize="24sp" android:textStyle="bold" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:padding="14dp" android:text="8" android:textColor="@color/text_white" android:textSize="24sp" android:textStyle="bold" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:padding="14dp" android:text="9" android:textColor="@color/text_white" android:textSize="24sp" android:textStyle="bold" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:padding="14dp" android:text="👆 Bio" android:textColor="@color/text_grey" android:textSize="14sp" android:textStyle="bold" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:padding="14dp" android:text="0" android:textColor="@color/text_white" android:textSize="24sp" android:textStyle="bold" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:padding="14dp" android:text="⌫" android:textColor="@color/text_grey" android:textSize="24sp" android:textStyle="bold" />
    </GridLayout>

    <Button
        android:id="@+id/btn_confirm_pin"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_margin="16dp"
        android:background="@drawable/btn_primary_bg"
        android:text="@string/confirm_and_pay"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/pin_footer" />

    <TextView
        android:id="@+id/pin_footer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="🔒 256-bit SSL  NPCI  End-to-end encrypted"
        android:textColor="@color/text_grey"
        android:textSize="9sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>