<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/container_confirm"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:visibility="gone">

    <LinearLayout
        android:id="@+id/confirm_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/btn_back_confirm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:text="← Back"
            android:textColor="@color/text_grey"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:text="@string/confirm_receiver"
            android:textColor="@color/text_white"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingBottom="16dp"
            android:text="@string/check_before"
            android:textColor="@color/text_grey"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/verify_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:background="@color/s2"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="22dp"
        app:layout_constraintTop_toBottomOf="@id/confirm_header">

        <TextView
            android:id="@+id/tv_confirm_receiver_initials"
            android:layout_width="68dp"
            android:layout_height="68dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/btn_primary_bg"
            android:gravity="center"
            android:text="PS"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_confirm_receiver_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Priya Singh"
            android:textColor="@color/text_white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_confirm_receiver_upi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="priya@oksbi"
            android:textColor="@color/text_grey"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tv_confirm_verified_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#2200F5A0"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:text="@string/upi_id_verified"
            android:textColor="@color/success_green"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/confirm_details_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/verify_card">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingVertical="10dp"
            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Bank"
                android:textColor="@color/text_grey"
                android:textSize="13sp" />
            <TextView
                android:id="@+id/tv_confirm_bank_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="State Bank of India"
                android:textColor="@color/text_white"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingVertical="10dp"
            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Verified Name"
                android:textColor="@color/text_grey"
                android:textSize="13sp" />
            <TextView
                android:id="@+id/tv_confirm_official_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PRIYA SINGH"
                android:textColor="@color/text_white"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btn_proceed_confirm"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/btn_primary_bg"
            android:text="@string/proceed_to_pay"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_wrong_person"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@color/s2"
            android:text="@string/wrong_person"
            android:textAllCaps="false"
            android:textColor="@color/text_white"
            android:textStyle="bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>