<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/container_bank_select"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:visibility="gone">

    <LinearLayout
        android:id="@+id/bank_select_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/btn_back_bank"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:text="← Back"
            android:textColor="@color/text_grey"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:text="@string/pay_from"
            android:textColor="@color/text_white"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingBottom="16dp"
            android:text="@string/choose_bank"
            android:textColor="@color/text_grey"
            android:textSize="12sp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/bank_footer_container"
        app:layout_constraintTop_toBottomOf="@id/bank_select_header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="20dp">

            <!-- SBI -->
            <LinearLayout
                android:id="@+id/row_bank_sbi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="9dp"
                android:background="@color/s3"
                android:padding="14dp"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">
                <TextView
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/wallet_card_bg"
                    android:backgroundTint="#003B8E"
                    android:gravity="center"
                    android:text="SBI"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="State Bank of India"
                        android:textColor="@color/text_white"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="•••• 4821"
                        android:textColor="@color/text_grey"
                        android:textSize="11sp" />
                    <TextView
                        android:id="@+id/tv_bank_balance_sbi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Check Balance"
                        android:textColor="@color/cyan"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>
                <TextView
                    android:id="@+id/check_sbi"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:background="@color/cyan"
                    android:gravity="center"
                    android:text="✓"
                    android:textColor="@color/black"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- HDFC -->
            <LinearLayout
                android:id="@+id/row_bank_hdfc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="9dp"
                android:background="@color/s2"
                android:padding="14dp"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">
                <TextView
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/wallet_card_bg"
                    android:backgroundTint="#8B0000"
                    android:gravity="center"
                    android:text="HDFC"
                    android:textColor="@color/white"
                    android:textSize="10sp"
                    android:textStyle="bold" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HDFC Bank"
                        android:textColor="@color/text_white"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="•••• 7733"
                        android:textColor="@color/text_grey"
                        android:textSize="11sp" />
                    <TextView
                        android:id="@+id/tv_bank_balance_hdfc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Check Balance"
                        android:textColor="@color/cyan"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>
                <TextView
                    android:id="@+id/check_hdfc"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:background="@drawable/pin_dot_empty"
                    android:gravity="center"
                    android:text=""
                    android:textColor="@color/black"
                    android:textSize="10sp" />
            </LinearLayout>

            <!-- ICICI -->
            <LinearLayout
                android:id="@+id/row_bank_icici"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="9dp"
                android:background="@color/s2"
                android:padding="14dp"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">
                <TextView
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/wallet_card_bg"
                    android:backgroundTint="#004C00"
                    android:gravity="center"
                    android:text="ICICI"
                    android:textColor="@color/white"
                    android:textSize="10sp"
                    android:textStyle="bold" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ICICI Bank"
                        android:textColor="@color/text_white"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="•••• 2290"
                        android:textColor="@color/text_grey"
                        android:textSize="11sp" />
                    <TextView
                        android:id="@+id/tv_bank_balance_icici"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Check Balance"
                        android:textColor="@color/cyan"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>
                <TextView
                    android:id="@+id/check_icici"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:background="@drawable/pin_dot_empty"
                    android:gravity="center"
                    android:text=""
                    android:textColor="@color/black"
                    android:textSize="10sp" />
            </LinearLayout>

            <!-- Add Bank -->
            <LinearLayout
                android:id="@+id/btn_add_bank_account"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/glass_btn_bg"
                android:backgroundTint="@color/bg_dark"
                android:padding="14dp"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">
                <TextView
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/glass_btn_bg"
                    android:gravity="center"
                    android:text="＋"
                    android:textColor="@color/cyan"
                    android:textSize="20sp" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Add New Bank Account"
                        android:textColor="@color/cyan"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Link via IFSC or Net Banking"
                        android:textColor="@color/text_grey"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bank_footer_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btn_confirm_bank"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/btn_primary_bg"
            android:text="@string/confirm_bank"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="12dp"
            android:text="Secured by NPCI UPI"
            android:textColor="@color/text_grey"
            android:textSize="10sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>