<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/container_scanner"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:visibility="gone">

    <!-- Camera Preview View -->
    <androidx.camera.view.PreviewView
        android:id="@+id/scanner_preview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Scan QR Code"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Align QR code within the frame"
            android:textColor="@color/text_grey"
            android:textSize="14sp" />

        <FrameLayout
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:layout_marginTop="40dp"
            android:background="@drawable/glass_btn_bg"
            android:backgroundTint="#11FFFFFF">

            <!-- Scanner Frame corners -->
            <View android:layout_width="40dp" android:layout_height="2dp" android:background="@color/cyan" android:layout_gravity="top|start" />
            <View android:layout_width="2dp" android:layout_height="40dp" android:background="@color/cyan" android:layout_gravity="top|start" />

            <View android:layout_width="40dp" android:layout_height="2dp" android:background="@color/cyan" android:layout_gravity="top|end" />
            <View android:layout_width="2dp" android:layout_height="40dp" android:background="@color/cyan" android:layout_gravity="top|end" />

            <View android:layout_width="40dp" android:layout_height="2dp" android:background="@color/cyan" android:layout_gravity="bottom|start" />
            <View android:layout_width="2dp" android:layout_height="40dp" android:background="@color/cyan" android:layout_gravity="bottom|start" />

            <View android:layout_width="40dp" android:layout_height="2dp" android:background="@color/cyan" android:layout_gravity="bottom|end" />
            <View android:layout_width="2dp" android:layout_height="40dp" android:background="@color/cyan" android:layout_gravity="bottom|end" />

            <View
                android:id="@+id/scanner_line"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="@color/cyan"
                android:layout_marginTop="0dp" />
        </FrameLayout>

        <TextView
            android:id="@+id/btn_mock_scan_trigger"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:background="@drawable/glass_btn_bg"
            android:paddingHorizontal="24dp"
            android:paddingVertical="12dp"
            android:text="Simulate Scan (Demo)"
            android:textColor="@color/cyan"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/btn_back_scanner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="24dp"
        android:text="✕ Close"
        android:textColor="@color/white"
        android:textSize="16sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>